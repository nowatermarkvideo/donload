<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ganz Downloader - TikTok, YT, IG, X Tanpa Watermark</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Roboto, sans-serif; -webkit-tap-highlight-color: transparent; }
        :root { --bg-dark: #0b0f19; --card-bg: #141b2d; --accent-color: #06b6d4; --text-main: #f8fafc; --text-muted: #94a3b8; --danger: #ef4444; --success: #22c55e; --border: #1e293b; }
        body { background-color: var(--bg-dark); color: var(--text-main); min-height: 100vh; display: flex; flex-direction: column; justify-content: space-between; }

        /* NAVBAR */
        header { background-color: rgba(11, 15, 25, 0.95); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100; }
        .navbar { display: flex; justify-content: space-between; align-items: center; padding: 14px 5%; max-width: 1000px; margin: auto; }
        .logo { font-size: 20px; font-weight: 800; color: var(--accent-color); text-decoration: none; display: flex; align-items: center; gap: 8px; }

        /* HERO SECTION */
        .hero { text-align: center; padding: 50px 20px 30px; max-width: 800px; margin: auto; }
        .hero h1 { font-size: 28px; font-weight: 800; margin-bottom: 10px; color: #fff; }
        .hero p { font-size: 14px; color: var(--text-muted); margin-bottom: 30px; }

        /* PLATFORMS BADGES */
        .platforms { display: flex; justify-content: center; gap: 12px; margin-bottom: 25px; flex-wrap: wrap; }
        .platform-badge { display: flex; align-items: center; gap: 6px; background: var(--card-bg); border: 1px solid var(--border); padding: 8px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; color: var(--text-muted); }
        .platform-badge.tiktok { color: #fe2c55; border-color: rgba(254, 44, 85, 0.3); }
        .platform-badge.youtube { color: #ff0000; border-color: rgba(255, 0, 0, 0.3); }
        .platform-badge.instagram { color: #e1306c; border-color: rgba(225, 48, 108, 0.3); }
        .platform-badge.twitter { color: #ffffff; border-color: rgba(255, 255, 255, 0.3); }

        /* DOWNLOAD BOX FORM */
        .container { max-width: 700px; margin: 0 auto 50px; padding: 0 15px; width: 100%; }
        .downloader-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; padding: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        
        .input-group { display: flex; gap: 10px; flex-direction: column; }
        @media(min-width: 576px) { .input-group { flex-direction: row; } }
        
        .input-wrapper { position: relative; flex-grow: 1; }
        .input-wrapper i { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--text-muted); }
        .input-wrapper input { width: 100%; padding: 14px 15px 14px 45px; background: var(--bg-dark); border: 1px solid var(--border); border-radius: 10px; color: white; font-size: 14px; outline: none; transition: 0.2s; }
        .input-wrapper input:focus { border-color: var(--accent-color); }

        .btn-download { padding: 14px 24px; background: var(--accent-color); color: #0f172a; border: none; border-radius: 10px; font-weight: bold; font-size: 14px; cursor: pointer; transition: 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; white-space: nowrap; }
        .btn-download:hover { opacity: 0.9; }

        /* ERROR MESSAGE */
        .error-box { display: none; margin-top: 15px; background: rgba(239, 68, 68, 0.15); border: 1px solid var(--danger); color: #f87171; padding: 10px; border-radius: 8px; font-size: 13px; text-align: center; }

        /* RESULT SECTION */
        .result-box { display: none; margin-top: 25px; background: var(--bg-dark); border: 1px solid var(--border); border-radius: 12px; padding: 20px; text-align: center; animation: fadeIn 0.3s ease; }
        .result-title { font-size: 14px; font-weight: bold; margin-bottom: 15px; color: white; }
        .btn-result { padding: 12px 24px; background: var(--success); color: white; text-decoration: none; border-radius: 8px; font-size: 13px; font-weight: bold; display: inline-flex; align-items: center; gap: 8px; transition: 0.2s; }
        .btn-result:hover { opacity: 0.9; }
        
        /* LOADER SPINNER */
        .loader { display: none; text-align: center; margin-top: 20px; font-size: 13px; color: var(--text-muted); }
        .loader i { color: var(--accent-color); animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }

        /* FOOTER */
        footer { text-align: center; padding: 20px; font-size: 12px; color: var(--text-muted); border-top: 1px solid var(--border); }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <header>
        <div class="navbar">
            <a href="#" class="logo"><i class="fa-solid fa-cloud-arrow-down"></i> GANZ DOWNLOADER</a>
        </div>
    </header>

    <!-- HERO CONTENT -->
    <div class="hero">
        <h1>Download Video Tanpa Watermark</h1>
        <p>Simpan video favoritmu dari TikTok, Instagram, YouTube, dan X secara instan & gratis.</p>
        
        <div class="platforms">
            <div class="platform-badge tiktok"><i class="fa-brands fa-tiktok"></i> TikTok</div>
            <div class="platform-badge youtube"><i class="fa-brands fa-youtube"></i> YouTube</div>
            <div class="platform-badge instagram"><i class="fa-brands fa-instagram"></i> Instagram</div>
            <div class="platform-badge twitter"><i class="fa-brands fa-x-twitter"></i> Twitter / X</div>
        </div>
    </div>

    <!-- MAIN FORM CONTAINER -->
    <div class="container">
        <div class="downloader-card">
            <form onsubmit="handleDownload(event)">
                <div class="input-group">
                    <div class="input-wrapper">
                        <i class="fa-solid fa-link"></i>
                        <input type="url" id="video-url" placeholder="Tempel tautan video di sini..." required>
                    </div>
                    <button type="submit" class="btn-download" id="submit-btn"><i class="fa-solid fa-download"></i> Download</button>
                </div>
            </form>

            <!-- ERROR NOTIFICATION -->
            <div class="error-box" id="error-box">Gagal mengambil video. Periksa kembali tautan Anda!</div>

            <!-- LOADING SPINNER -->
            <div class="loader" id="loader-box">
                <i class="fa-solid fa-circle-notch fa-lg"></i> Menghubungkan ke server & memproses video...
            </div>

            <!-- HASIL DOWNLOAD -->
            <div class="result-box" id="result-box">
                <div class="result-title"><i class="fa-solid fa-circle-check" style="color:var(--success)"></i> Video Berhasil Diproses!</div>
                <div id="download-actions">
                    <!-- Tombol download akan muncul otomatis di sini -->
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer>
        &copy; 2026 Ganz Downloader. All rights reserved.
    </footer>

    <!-- JAVASCRIPT LOGIC -->
    <script>
        async function handleDownload(event) {
            event.preventDefault();
            const urlInput = document.getElementById('video-url').value.trim();
            const loaderBox = document.getElementById('loader-box');
            const resultBox = document.getElementById('result-box');
            const errorBox = document.getElementById('error-box');
            const downloadActions = document.getElementById('download-actions');

            // Reset tampilan
            resultBox.style.display = 'none';
            errorBox.style.display = 'none';
            loaderBox.style.display = 'block';

            try {
                // Menggunakan API publik Cobalt.tools untuk mengunduh media
                const response = await fetch("https://co.wuk.sh/api/json", {
                    method: "POST",
                    headers: {
                        "Accept": "application/json",
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        url: urlInput,
                        vQuality: "720"
                    })
                });

                const data = await response.json();
                loaderBox.style.display = 'none';

                if (data.status === "redirect" || data.status === "stream" || data.status === "success") {
                    const downloadUrl = data.url || (data.picker && data.picker[0].url);
                    
                    if (downloadUrl) {
                        downloadActions.innerHTML = `<a href="${downloadUrl}" class="btn-result" target="_blank" download><i class="fa-solid fa-download"></i> Unduh File Sekarang</a>`;
                        resultBox.style.display = 'block';
                    } else {
                        showError("Tautan unduhan tidak ditemukan dalam respons server.");
                    }
                } else if (data.status === "picker") {
                    // Jika ada beberapa pilihan file (misal foto carousel IG atau pilihan resolusi)
                    let buttonsHTML = "";
                    data.picker.forEach((item, index) => {
                        buttonsHTML += `<a href="${item.url}" class="btn-result" target="_blank" style="margin: 5px;" download><i class="fa-solid fa-download"></i> Download Bagian ${index + 1}</a>`;
                    });
                    downloadActions.innerHTML = buttonsHTML;
                    resultBox.style.display = 'block';
                } else {
                    showError(data.text || "Gagal memproses tautan. Pastikan link video publik dan valid.");
                }

            } catch (err) {
                loaderBox.style.display = 'none';
                showError("Terjadi kesalahan jaringan atau server sedang sibuk.");
                console.error(err);
            }
        }

        function showError(message) {
            const errorBox = document.getElementById('error-box');
            errorBox.innerText = message;
            errorBox.style.display = 'block';
        }
    </script>
</body>
</html>
