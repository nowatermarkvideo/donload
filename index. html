<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ganz Video Downloader - Tanpa Watermark</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Roboto, sans-serif; -webkit-tap-highlight-color: transparent; }
        :root { --bg-dark: #0b0f19; --card-bg: #141b2d; --accent-color: #06b6d4; --text-main: #f8fafc; --text-muted: #94a3b8; --border: #1e293b; --success: #22c55e; --danger: #ef4444; }
        body { background-color: var(--bg-dark); color: var(--text-main); min-height: 100vh; display: flex; flex-direction: column; justify-content: space-between; }

        header { background-color: rgba(11, 15, 25, 0.95); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100; }
        .navbar { display: flex; justify-content: space-between; align-items: center; padding: 14px 5%; max-width: 900px; margin: auto; }
        .logo { font-size: 18px; font-weight: 800; color: var(--accent-color); text-decoration: none; display: flex; align-items: center; gap: 8px; }

        .main-container { max-width: 750px; margin: 40px auto; padding: 0 20px; width: 100%; text-align: center; }
        
        .hero-title { font-size: 26px; font-weight: 800; line-height: 1.4; margin-bottom: 12px; color: #fff; }
        .hero-desc { font-size: 14px; color: var(--text-muted); margin-bottom: 30px; line-height: 1.5; }

        .platforms-list { display: flex; justify-content: center; gap: 10px; margin-bottom: 30px; flex-wrap: wrap; }
        .p-badge { background: var(--card-bg); border: 1px solid var(--border); padding: 6px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; color: var(--text-muted); display: flex; align-items: center; gap: 6px; }

        /* BOX INPUT UTAMA */
        .downloader-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; padding: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); text-align: left; }
        
        .input-box-wrapper { position: relative; margin-bottom: 15px; }
        .input-box-wrapper input { width: 100%; padding: 14px 15px 14px 45px; background: var(--bg-dark); border: 1px solid var(--border); border-radius: 10px; color: white; font-size: 14px; outline: none; transition: 0.2s; }
        .input-box-wrapper input:focus { border-color: var(--accent-color); }
        .input-box-wrapper i { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--text-muted); }

        .btn-action-group { display: flex; gap: 10px; }
        .btn-download { flex-grow: 1; padding: 14px; background: var(--accent-color); color: #0f172a; border: none; border-radius: 10px; font-weight: bold; font-size: 14px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: 0.2s; }
        .btn-download:hover { opacity: 0.9; }

        .trial-note { text-align: center; font-size: 12px; color: var(--text-muted); margin-top: 15px; }

        /* ERROR & LOADING */
        .error-box { display: none; margin-top: 15px; background: rgba(239, 68, 68, 0.15); border: 1px solid var(--danger); color: #f87171; padding: 10px; border-radius: 8px; font-size: 13px; text-align: center; }
        .loader { display: none; text-align: center; margin-top: 20px; font-size: 13px; color: var(--text-muted); }
        .loader i { color: var(--accent-color); animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        /* HASIL DOWNLOAD */
        .result-box { display: none; margin-top: 20px; background: var(--bg-dark); border: 1px solid var(--border); border-radius: 12px; padding: 20px; text-align: center; }
        .btn-result-file { display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: var(--success); color: white; text-decoration: none; border-radius: 8px; font-weight: bold; font-size: 13px; margin-top: 10px; }

        footer { text-align: center; padding: 20px; font-size: 12px; color: var(--text-muted); border-top: 1px solid var(--border); }
    </style>
</head>
<body>

    <header>
        <div class="navbar">
            <a href="#" class="logo"><i class="fa-solid fa-cloud-arrow-down"></i> GANZ DOWNLOADER</a>
        </div>
    </header>

    <div class="main-container">
        <h1 class="hero-title">Unduh Video Tanpa Watermark — Bersih, Cepat, & Gratis.</h1>
        <p class="hero-desc">Tempel tautan video dari TikTok, Instagram, YouTube, atau Twitter untuk langsung mengunduhnya tanpa tanda air.</p>

        <div class="platforms-list">
            <div class="p-badge" style="color:#fe2c55"><i class="fa-brands fa-tiktok"></i> TikTok</div>
            <div class="p-badge" style="color:#e1306c"><i class="fa-brands fa-instagram"></i> Instagram</div>
            <div class="p-badge" style="color:#ff0000"><i class="fa-brands fa-youtube"></i> YouTube</div>
            <div class="p-badge" style="color:#fff"><i class="fa-brands fa-x-twitter"></i> Twitter / X</div>
        </div>

        <div class="downloader-card">
            <form onsubmit="processDownload(event)">
                <div class="input-box-wrapper">
                    <i class="fa-solid fa-link"></i>
                    <input type="url" id="target-url" placeholder="Tempel tautan video di sini (contoh: https://vt.tiktok.com/...)" required>
                </div>
                <div class="btn-action-group">
                    <button type="submit" class="btn-download"><i class="fa-solid fa-download"></i> Unduh Video</button>
                </div>
            </form>

            <div class="error-box" id="error-box">Gagal memproses tautan. Pastikan link publik dan valid!</div>

            <div class="loader" id="loader-box">
                <i class="fa-solid fa-circle-notch fa-lg"></i> Menghubungkan ke server & membersihkan watermark...
            </div>

            <div class="result-box" id="result-box">
                <div style="font-size: 14px; font-weight: bold; margin-bottom: 5px; color: white;"><i class="fa-solid fa-circle-check" style="color:var(--success)"></i> Video Berhasil Disiapkan!</div>
                <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 12px;">File siap diunduh tanpa tanda air.</div>
                <div id="action-download-btn"></div>
            </div>
        </div>

        <div class="trial-note">Gratis digunakan sepuasnya — tanpa instalasi aplikasi tambahan.</div>
    </div>

    <footer>
        &copy; 2026 Ganz Downloader. All rights reserved.
    </footer>

    <script>
        async function processDownload(e) {
            e.preventDefault();
            const urlInput = document.getElementById('target-url').value.trim();
            const loader = document.getElementById('loader-box');
            const result = document.getElementById('result-box');
            const errorBox = document.getElementById('error-box');
            const actionBtn = document.getElementById('action-download-btn');

            result.style.display = 'none';
            errorBox.style.display = 'none';
            loader.style.display = 'block';

            try {
                // Menggunakan API publik open-source untuk unduh media tanpa watermark
                const response = await fetch("https://co.wuk.sh/api/json", {
                    method: "POST",
                    headers: {
                        "Accept": "application/json",
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        url: urlInput,
                        vQuality: "720"
                    })
                });

                const data = await response.json();
                loader.style.display = 'none';

                if (data.status === "redirect" || data.status === "stream" || data.status === "success") {
                    const downloadUrl = data.url || (data.picker && data.picker[0].url);
                    if (downloadUrl) {
                        actionBtn.innerHTML = `<a href="${downloadUrl}" class="btn-result-file" target="_blank" download><i class="fa-solid fa-file-arrow-down"></i> Download Video Bersih</a>`;
                        result.style.display = 'block';
                    } else {
                        showError("Tautan unduhan tidak ditemukan.");
                    }
                } else {
                    showError(data.text || "Gagal memproses tautan. Cek kembali link yang kamu masukkan.");
                }
            } catch (err) {
                loader.style.display = 'none';
                showError("Terjadi kesalahan koneksi ke server.");
            }
        }

        function showError(msg) {
            const errorBox = document.getElementById('error-box');
            errorBox.innerText = msg;
            errorBox.style.display = 'block';
        }
    </script>
</body>
</html>
